# Entorno general de la aplicación.
APP_ENV=development
APP_DEBUG=true
APP_NAME="Caldera Biomasa Domótica"

# Conexión MySQL de desarrollo sin credenciales reales.
DB_HOST=localhost
DB_PORT=3306
DB_NAME=caldera_biomasa
DB_USER=usuario_desarrollo
DB_PASS=cambiar_en_local
DB_CHARSET=utf8mb4

# Seguridad de dispositivo en desarrollo.
DEVICE_API_KEY=cambiar_en_local
