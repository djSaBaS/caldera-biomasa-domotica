# Entorno general de la aplicación.
APP_ENV=development
APP_DEBUG=true
APP_NAME="Caldera Biomasa Domótica"

# Conexión MySQL de desarrollo sin credenciales reales.
DB_HOST=localhost
DB_PORT=3306
DB_NAME=caldera_biomasa
DB_USER=usuario_desarrollo
DB_PASS=REEMPLAZAR_EN_LOCAL
DB_CHARSET=utf8mb4

# Seguridad de dispositivo en desarrollo.
# IMPORTANTE: este valor documental será rechazado por el backend.
# Genera una clave local larga antes de probar endpoints protegidos.
DEVICE_API_KEY=REEMPLAZAR_POR_UNA_CLAVE_LARGA_ALEATORIA
